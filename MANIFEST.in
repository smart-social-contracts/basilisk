recursive-include basilisk/compiler *.py *.rs *.toml *.c *.h *.sh *.json *.wasm *.a
recursive-include basilisk/canisters *.py *.did
recursive-include basilisk/templates *
include basilisk/py.typed
recursive-exclude basilisk/templates/*/.basilisk *
recursive-exclude basilisk/templates/*/.dfx *
recursive-exclude basilisk/compiler/*/target *
recursive-exclude basilisk/compiler/*/.basilisk *
prune basilisk/compiler/cpython_canister_template/target
prune basilisk/compiler/basilisk_cpython/target
prune basilisk/compiler/basilisk_generate/target
