{
    "canisters": {
        "shell_test": {
            "type": "custom",
            "build": "CANISTER_CANDID_PATH=./shell_test.did python -m basilisk shell_test src/main.py",
            "candid": "shell_test.did",
            "wasm": ".basilisk/shell_test/shell_test.wasm",
            "gzip": true,
            "metadata": [
                {
                    "name": "candid:service"
                }
            ]
        }
    },
    "networks": {
        "local": {
            "bind": "127.0.0.1:4943",
            "type": "ephemeral"
        },
        "ic": {
            "providers": ["https://icp0.io"],
            "type": "persistent"
        }
    }
}
